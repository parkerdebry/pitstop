# ─────────────────────────────────────────────────────────────────────
# PitStop — Environment Variables
# Copy this to .env.local and fill in your values.
# Variables prefixed NEXT_PUBLIC_ are exposed to the browser.
# ─────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ── Anthropic (AI Mechanic) ───────────────────────────────────────────
# https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ── SmartCar ─────────────────────────────────────────────────────────
# https://dashboard.smartcar.com → Applications
# Set redirect URI to: https://your-app.vercel.app/api/smartcar/callback
SMARTCAR_CLIENT_ID=
SMARTCAR_CLIENT_SECRET=
SMARTCAR_REDIRECT_URI=https://your-app.vercel.app/api/smartcar/callback

# ── Stripe ───────────────────────────────────────────────────────────
# https://dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Create products in Stripe Dashboard → Products, copy the Price IDs
STRIPE_PRICE_ANNUAL=price_...
STRIPE_PRICE_MONTHLY=price_...
